.chat-sidebar
  .d-flex.justify-content-between.align-items-center.mb-2
    h6.mb-0 Chat with your data
    .d-flex.gap-1
      button.btn.btn-sm.btn-outline-secondary#chat-history-btn(title="Conversation history")
        != icon('history')
      button.btn.btn-sm.btn-outline-secondary#clear-chat(title="New conversation")
        != icon('add')

  //- Project filter is hidden when the account has a single project (chat.js)
  .mb-2.d-none#chat-project-filter-wrap
    select.form-select.form-select-sm#chat-project-filter
      option(value="") All projects
      //- Populated dynamically by chat.js

  #chat-messages.overflow-auto.flex-grow-1
    #chat-welcome
      .chat-welcome-greeting
        h5.mb-1 Hello #{user.name || 'there'}
        p.mb-3 What would you like to do?
      .chat-welcome-examples.mt-3
        button.chat-example-btn.mb-1(type="button") What topics or themes are most common
        button.chat-example-btn.mb-1(type="button") Summarise my most recent notes
        button.chat-example-btn.mb-1(type="button") Which memories mention a specific decision
        button.chat-example-btn.mb-1(type="button") Search across all my saved URLs
        button.chat-example-btn.mb-1(type="button") Show me usage statistics

  .mt-auto.pt-2
    .input-group
      input.form-control#chat-input(type="text" placeholder="Ask, search, or give a command...")
      button.btn.btn-primary#chat-send
        != icon('send')
