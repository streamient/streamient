//- OpenObserve RUM + Browser Logs
if openobserve && openobserve.enabled && openobserve.clientToken && (openobserve.rumEnabled || openobserve.browserLogsEnabled)
	- const ooCurrentUser = typeof user !== 'undefined' ? user : null;
	- const ooHostId = typeof host_id !== 'undefined' ? host_id : '';
	- const ooOptions = JSON.stringify({ applicationId: openobserve.applicationId, clientToken: openobserve.clientToken, site: openobserve.site, organizationIdentifier: openobserve.organizationIdentifier, service: openobserve.service, env: openobserve.env, version: openobserve.version, apiVersion: openobserve.apiVersion, insecureHTTP: openobserve.insecureHTTP, defaultPrivacyLevel: openobserve.defaultPrivacyLevel, rumEnabled: openobserve.rumEnabled, browserLogsEnabled: openobserve.browserLogsEnabled, sessionReplayEnabled: openobserve.sessionReplayEnabled });
	- const ooUser = ooCurrentUser ? JSON.stringify({ id: String(ooCurrentUser._id), name: ooCurrentUser.name, email: ooCurrentUser.email, host_id: ooHostId || '', subscription_status: ooCurrentUser.subscription_status || 'free' }) : 'null';
	script(type="module").
		import { openobserveRum, openobserveLogs } from '/static/v-#{v}/js/vendor.js';

		const options = !{ooOptions};
		const userContext = !{ooUser};
		try {
			if (options.rumEnabled) {
				openobserveRum.init({
					applicationId: options.applicationId,
					clientToken: options.clientToken,
					site: options.site,
					organizationIdentifier: options.organizationIdentifier,
					service: options.service,
					env: options.env,
					version: options.version,
					trackResources: true,
					trackLongTasks: true,
					trackUserInteractions: true,
					apiVersion: options.apiVersion,
					insecureHTTP: options.insecureHTTP,
					defaultPrivacyLevel: options.defaultPrivacyLevel
				});
				if (userContext) {
					openobserveRum.setUser(userContext);
				} else if (typeof openobserveRum.clearUser === 'function') {
					openobserveRum.clearUser();
				}
				if (options.sessionReplayEnabled && typeof openobserveRum.startSessionReplayRecording === 'function') {
					openobserveRum.startSessionReplayRecording();
				}
			}
			if (options.browserLogsEnabled) {
				openobserveLogs.init({
					clientToken: options.clientToken,
					site: options.site,
					organizationIdentifier: options.organizationIdentifier,
					service: options.service,
					env: options.env,
					version: options.version,
					forwardErrorsToLogs: true,
					insecureHTTP: options.insecureHTTP,
					apiVersion: options.apiVersion
				});
			}
			const previousCaptureEvent = window.captureEvent;
			window.captureEvent = function(eventOptions) {
				if (typeof previousCaptureEvent === 'function') previousCaptureEvent(eventOptions);
				eventOptions = eventOptions || {};
				if (!eventOptions.action || !options.rumEnabled || typeof openobserveRum.addAction !== 'function') return;
				openobserveRum.addAction(eventOptions.action, {
					host_id: '#{ooHostId || ""}',
					subscription_status: '#{ooCurrentUser ? (ooCurrentUser.subscription_status || "free") : ""}'
				});
			};
		} catch (error) {
			console.error('OpenObserve browser init error:', error);
		}
