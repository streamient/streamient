doctype html
html(lang="en")
	head
		meta(charset="UTF-8")
		meta(name="viewport" content="width=device-width, initial-scale=1")
		title #{title || 'Admin — Streamient'}
		link(href='/static/images/favicon.ico' rel="shortcut icon")
		script.
			(function () {
				try {
					var t = localStorage.getItem('kk-theme');
					if (t !== 'light' && t !== 'dark') t = 'dark';
					document.documentElement.setAttribute('data-theme', t);
					document.documentElement.setAttribute('data-bs-theme', t);
				} catch (e) {
					document.documentElement.setAttribute('data-theme', 'dark');
					document.documentElement.setAttribute('data-bs-theme', 'dark');
				}
			})();
		link(href=`/static/v-${v}/css/admin_vendor.css` rel="stylesheet")
		link(href=`/static/v-${v}/css/app.css` rel="stylesheet")
		link(href=`/static/v-${v}/css/streamient-tabler.css` rel="stylesheet")
		block head
		style.
			html, body { height: 100%; }
			body { display: flex; flex-direction: column; }
			.admin-main { flex: 1; }
			.admin-footer { flex-shrink: 0; }
	body
		nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.sticky-top
			.container-fluid
				a.navbar-brand.ms-2(href="/admin") Streamient Admin
				.d-flex.align-items-center
					ul.navbar-nav.me-3
						block nav
							if is_hosted
								li.nav-item
									a.nav-link(href="/admin" class=(activeNav === 'accounts' ? 'active' : '')) Accounts
							li.nav-item
								a.nav-link(href="/admin/email-templates" class=(activeNav === 'email-templates' ? 'active' : '')) Email Templates
						li.nav-item
								a.nav-link(href="/admin/audit-logs" class=(activeNav === 'audit-logs' ? 'active' : '')) Audit Logs
					form(action="/admin/logout" method="POST")
						button.btn.btn-outline-light.btn-sm(type="submit")
							!= icon('signOut', 'me-1')
							| Logout

		.container-fluid.admin-main.py-4
			block content

		.container-fluid.bg-body.admin-footer.mb-5
			.d-flex.align-items-center.justify-content-center.fs-9
				a(href="https://streamient.com?utm_source=streamient_admin&utm_medium=referral" target="_blank") Streamient
				span.ps-1 Made by the Founders who also run
				a.ps-1(href="https://helpmonks.com?utm_source=streamient_admin&utm_medium=referral" target="_blank") Helpmonks - Email Management
				span.ps-1 and
				a.ps-1(href="https://razuna.com?utm_source=streamient_admin&utm_medium=referral" target="_blank") Razuna - Digital Asset Management

		script(src=`/static/v-${v}/js/icons.js`)
		script(src=`/static/v-${v}/js/autofill_guard.js`)
		script(src=`/static/v-${v}/js/vendor.js` type="module")
		block scripts
