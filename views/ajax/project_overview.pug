- const createdAt = new Date(project.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
- const pc = counts[project._id.toString()] || { notes: 0, memory: 0, urls: 0, emails: 0 }
- const forwardingEmail = emailForwardDomain ? `${project._id}@${emailForwardDomain}` : ''

.d-flex.justify-content-between.align-items-center.mb-2
	.d-flex.align-items-center.gap-2
		span.project-color(style=`background:${project.color}; width:16px; height:16px`)
		h4.mb-0= project.name
	.ms-auto
		if !project.is_default
			if canDelete
				button.btn.btn-sm.btn-link.me-3.fs-7(onclick=`deleteProject('${project._id}')`) Delete
			button.btn.btn-sm.btn-outline-secondary(onclick=`editProject('${project._id}')`) Edit Project
		else
			button.btn.btn-sm.btn-outline-secondary(onclick=`editProject('${project._id}')`) Edit Project

.d-flex.w-100.align-items-center.mb-4
	.text-muted.small.fs-7.user-select-all #{project._id}
	.ms-auto
		span.text-muted.small.fs-7 Created #{createdAt}

.row.g-3.mb-5
	.col-md-3
		a.text-decoration-none.project-section-link(href="/notes" data-project=project._id)
			.card.h-100
				.card-body.text-center
					.fs-3.fw-bold= pc.notes
					.text-muted Notes
	.col-md-3
		a.text-decoration-none.project-section-link(href="/memories" data-project=project._id)
			.card.h-100
				.card-body.text-center
					.fs-3.fw-bold= pc.memory
					.text-muted Memories
	.col-md-3
		a.text-decoration-none.project-section-link(href="/urls" data-project=project._id)
			.card.h-100
				.card-body.text-center
					.fs-3.fw-bold= pc.urls
					.text-muted URLs
	.col-md-3
		if emailFeatureEnabled
			a.text-decoration-none.project-section-link(href="/emails" data-project=project._id)
				.card.h-100
					.card-body.text-center
						.fs-3.fw-bold= pc.emails
						.text-muted Emails
		else
			.card.h-100.border-warning-subtle
				.card-body.text-center
					.fs-3.fw-bold.text-muted
						!= icon('lock')
					.text-muted.mb-2 Emails (Pro)
					if is_hosted
						a.btn.btn-sm.btn-outline-warning(href="/settings/subscription") Upgrade


if gitSyncEnabled
	.mt-4
		.d-flex.justify-content-between.align-items-center.mb-3
			h5.mb-0
				!= icon('gitBranch')
				span.ms-2 Git Sync
			button.btn.btn-sm.btn-outline-primary(onclick=`addGitRepo('${project._id}')`) Add Repo

		if gitRepos && gitRepos.length
			.list-group
				each repo in gitRepos
					.list-group-item
						.d-flex.align-items-start.mb-3
							.d-flex.flex-column
								.mb-2
									.fw-bold= repo.name || repo.repo_url
									.text-muted.small= repo.repo_url
								if repo.last_sync_summary
									- const gs = repo.last_sync_summary
									.text-muted.small.mt-1
										span= `${gs.imported_files || 0} imported · ${gs.exported_files || 0} exported · ${gs.imported_commits || 0} commits · ${gs.trashed_items || 0} trashed · ${gs.conflicts || 0} conflicts`
							.ms-auto
								button.btn.btn-sm.btn-outline-primary.me-1(onclick=`triggerGitSync('${repo._id}')` title="Sync now")
									!= icon('sync')
								button.btn.btn-sm.btn-outline-secondary.me-1(onclick=`showGitSyncLogs('${repo._id}')` title="Sync log")
									!= icon('history')
								button.btn.btn-sm.btn-outline-secondary.me-1(onclick=`editGitRepo('${repo._id}')` title="Settings")
									!= icon('gear')
								button.btn.btn-sm.btn-outline-secondary(onclick=`deleteGitRepo('${repo._id}')` title="Remove")
									!= icon('delete')
						.d-flex.align-items-center
							if repo.enabled
								span.badge.bg-success.me-2 Enabled
							else
								span.badge.bg-secondary.me-2 Disabled
							if repo.last_sync_status === 'success'
								span.badge.bg-info Last sync: success
							else if repo.last_sync_status === 'failed'
								span.badge.bg-danger.cursor-pointer(title=repo.last_sync_error) Last sync: failed
							else if repo.last_sync_status === 'in_progress'
								span.badge.bg-warning Syncing…
							//- if repo.last_synced_at
							//- 	span.text-muted.small.fs-9= 'Last synced ' + new Date(repo.last_synced_at).toLocaleString()
							//- if repo.commit_sync_enabled !== false && repo.last_commit_synced_at
							//- 	span.text-muted.small.ps-3.fs-9= 'Last commits synced ' + new Date(repo.last_commit_synced_at).toLocaleString()
		else
			p.text-muted.small No git repos configured. Add one to sync markdown files.
else
	.my-4
		.card.border-warning-subtle
			.card-body
				h5.mb-2
					!= icon('lock', 'me-2')
					| Git Sync (Pro)
				p.text-muted.mb-2 Sync commit messages, markdown files, and more from your repository into your project.
				if is_hosted
					a.btn.btn-sm.btn-outline-warning(href="/settings/subscription") Upgrade to Pro

if emailFeatureEnabled
	.my-5
		.d-flex.justify-content-between.align-items-center.mb-3
			h5.mb-0
				!= icon('email')
				span.ms-2 Email Forwarding

		if forwardingEmail
			p.text-muted.small Forward emails to this address to import your emails into this project.
			.nowrap
				.input-group.input-group-sm.d-inline-flex.w-auto
					input.form-control#project-forwarding-email(type="text" readonly value=forwardingEmail aria-label="Forwarding email address" style=`width:${forwardingEmail.length + 5}ch; flex:0 0 auto; max-width:calc(100vw - 180px)`)
					button.btn.btn-outline-secondary#copy-forwarding-email-btn(type="button" data-copy-value=forwardingEmail title="Copy forwarding email")
						!= icon('copy')
		else
			.alert.alert-warning.mb-0 EMAIL_FORWARD_DOMAIN is not configured.
else
	.my-5
		.card.border-warning-subtle
			.card-body
				h5.mb-2
					!= icon('lock', 'me-2')
					| Email Forwarding (Pro)
				p.text-muted.mb-2 Forward emails directly into a project.
				if is_hosted
					a.btn.btn-sm.btn-outline-warning(href="/settings/subscription") Upgrade to Pro

//- Delete hint (always at bottom, outside gitSyncEnabled block)
if !project.is_default && !canDelete
	p.text-muted.fs-7.mt-auto.pt-4 Projects can only be deleted when all notes, memories, URLs, emails, and git repos have been removed.
