- const forwardingEmail = emailForwardDomain ? `${project._id}@${emailForwardDomain}` : ''

.row.project-settings-shell(data-project-id=project._id)
	.col-md-3
		.list-group.mb-3.project-settings-menu
			button.list-group-item.list-group-item-action.active(type="button" data-project-settings-tab="details")
				!= icon('gear', 'me-2')
				span Project details
			button.list-group-item.list-group-item-action(type="button" data-project-settings-tab="git")
				!= icon('gitBranch', 'me-2')
				span Git sync
			button.list-group-item.list-group-item-action(type="button" data-project-settings-tab="email")
				!= icon('email', 'me-2')
				span Email settings
	.col-md-9
		.project-settings-pane(data-project-settings-pane="details")
			h4.mb-4 Project details
			form#project-details-form
				.mb-3
					label.form-label(for="project-settings-name") Name
					input.form-control.form-control-sm#project-settings-name(type="text" value=project.name autocomplete="off")
					.mb-3
						label.form-label(for="project-settings-color") Color
						.d-flex.align-items-center.gap-3.project-settings-color-row
							span.project-color#project-settings-color-preview(style=`background:${project.color}; width:20px; height:20px`)
							.flex-grow-1
								input.form-control.form-control-sm#project-settings-color(type="text" value=project.color autocomplete="off")
				.d-flex.justify-content-end.mt-3
					button.btn.btn-primary.btn-sm(type="submit")
						!= icon('check', 'me-1')
						span Save Changes

		.project-settings-pane.d-none(data-project-settings-pane="git")
			.d-flex.justify-content-between.align-items-center.mb-4
				h4.mb-0 Git sync
				if gitSyncEnabled
					button.btn.btn-sm.btn-outline-primary(type="button" onclick=`addGitRepo('${project._id}')`)
						!= icon('add', 'me-1')
						span Add Repo
			if gitSyncEnabled
				if gitRepos && gitRepos.length
					.list-group
						each repo in gitRepos
							.list-group-item
								.d-flex.align-items-start.mb-3
									.d-flex.flex-column.min-w-0
										.mb-2
											.fw-bold.text-break= repo.name || repo.repo_url
											.text-muted.small.text-break= repo.repo_url
										if repo.last_sync_summary
											- const gs = repo.last_sync_summary
											.text-muted.small.mt-1
												span= `${gs.imported_files || 0} imported · ${gs.exported_files || 0} exported · ${gs.imported_commits || 0} commits · ${gs.trashed_items || 0} trashed · ${gs.conflicts || 0} conflicts`
									.ms-auto.text-nowrap
										button.btn.btn-sm.btn-outline-primary.me-1(type="button" onclick=`triggerGitSync('${repo._id}')` title="Sync now")
											!= icon('sync')
										button.btn.btn-sm.btn-outline-secondary.me-1(type="button" onclick=`showGitSyncLogs('${repo._id}')` title="Sync log")
											!= icon('history')
										button.btn.btn-sm.btn-outline-secondary.me-1(type="button" onclick=`editGitRepo('${repo._id}')` title="Settings")
											!= icon('gear')
										button.btn.btn-sm.btn-outline-secondary(type="button" onclick=`deleteGitRepo('${repo._id}')` title="Remove")
											!= icon('delete')
								.d-flex.align-items-center
									if repo.enabled
										span.badge.bg-success.me-2 Enabled
									else
										span.badge.bg-secondary.me-2 Disabled
									if repo.sync_mode === 'read_write'
										span.badge.bg-warning.me-2(title="Exports notes/memories back to git") Read/write
									else
										span.badge.bg-light.text-dark.me-2(title="Imports only — never writes to your repo") Read-only
									if repo.last_sync_status === 'success'
										span.badge.bg-info Last sync: success
									else if repo.last_sync_status === 'failed'
										span.badge.bg-danger.cursor-pointer(title=repo.last_sync_error) Last sync: failed
									else if repo.last_sync_status === 'in_progress'
										span.badge.bg-warning Syncing
				else
					p.text-muted.small.mb-0 No git repos configured. Add one to sync markdown files.
			else
				.card.border-warning-subtle
					.card-body
						h5.mb-2
							!= icon('lock', 'me-2')
							span Git Sync (Pro)
						p.text-muted.mb-2 Sync commit messages, markdown files, and more from your repository into your project.
						if is_hosted
							a.btn.btn-sm.btn-outline-warning(href="/settings/subscription") Upgrade to Pro

		.project-settings-pane.d-none(data-project-settings-pane="email")
			.mb-4
				h4.mb-0 Email settings
			if emailFeatureEnabled
				.mb-5
					h6.mb-2 Email forwarding
					if forwardingEmail
						p.text-muted.small.mb-2 Forward emails to this address to import your emails into this project.
						.input-group.input-group-sm.w-auto.project-forwarding-copy
							input.form-control.form-control-sm#project-settings-forwarding-email(type="text" readonly value=forwardingEmail aria-label="Forwarding email address")
							button.btn.btn-outline-secondary#project-settings-copy-forwarding-email(type="button" data-copy-value=forwardingEmail title="Copy forwarding email")
								!= icon('copy')
					else
						.alert.alert-warning.mb-0 EMAIL_FORWARD_DOMAIN is not configured.

				.mb-5
					h6.mb-2 Email filter
					form#project-email-filter-form
						textarea.form-control.form-control-sm#project-settings-email-filter(
							rows="5"
							autocomplete="off"
							autocorrect="off"
							autocapitalize="off"
							spellcheck="false"
							data-1p-ignore="true"
							data-op-ignore="true"
							data-lpignore="true"
							data-bwignore="true"
							data-form-type="other"
						)= project.email_filter
						.form-text.mt-2 Matching imported emails are moved to trash. Enter rules separated by new lines or commas: full address, domain, local part, or subject rule.
						.d-flex.justify-content-between.align-items-center.mt-2
							button.btn.btn-outline-secondary.btn-sm#project-email-filter-apply-btn(type="button")
								!= icon('sync', 'me-1')
								span Apply filters now
							button.btn.btn-primary.btn-sm(type="submit")
								!= icon('check', 'me-1')
								span Save filter
					.modal.fade#project-email-filter-apply-modal(tabindex="-1" aria-labelledby="project-email-filter-apply-modal-title" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false")
						.modal-dialog.modal-dialog-centered.modal-sm
							.modal-content
								.modal-header
									h5.modal-title#project-email-filter-apply-modal-title Apply filters
								.modal-body
									.d-flex.align-items-center.mb-3
										.spinner-border.spinner-border-sm.text-primary.me-3#project-email-filter-apply-spinner(role="status" aria-hidden="true")
										div
											.fw-semibold#project-email-filter-apply-status Applying filters
											.text-muted.small#project-email-filter-apply-detail Checking project inbox and labeled emails.
									.row.g-3.text-center
										.col
											.h6.mb-1#project-email-filter-apply-processed 0
											.small.text-muted Checked
										.col
											.h6.mb-1#project-email-filter-apply-moved 0
											.small.text-muted Moved
								.modal-footer
									button.btn.btn-secondary.btn-sm#project-email-filter-apply-close(type="button" data-bs-dismiss="modal" disabled) Close

			else
				.card.border-warning-subtle
					.card-body
						h5.mb-2
							!= icon('lock', 'me-2')
							span Email settings (Pro)
						p.text-muted.mb-2 Forward emails directly into a project.
						if is_hosted
							a.btn.btn-sm.btn-outline-warning(href="/settings/subscription") Upgrade to Pro
