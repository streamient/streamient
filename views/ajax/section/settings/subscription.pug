.row
	.col-md-3
		include _sidebar
	.col-md-9
		h4.mb-4 Subscription

		.card.mb-4
			.card-body
				h5.card-title
					!= icon('creditCard', 'me-2')
					span My Subscription

				- var bu = billing_user || user
				- var status = (bu && bu.subscription_status) || 'incomplete'
				- var isPro = plan === 'pro' || status === 'active'

				if isPro
					.alert.alert-success.mb-3
						!= icon('checkCircle', 'me-2')
						span Your Pro subscription is active.
				else if is_trialing
					.alert.alert-info.mb-3
						!= icon('clock', 'me-2')
						span Your 7-day Pro trial is active.
						strong.ms-1= trial_ends_text
						span .
				else if status === 'past_due'
					.alert.alert-warning.mb-3
						!= icon('warning', 'me-2')
						span Your payment is past due. Please update your payment method to keep Pro features.
				else
					.alert.alert-secondary.mb-3
						!= icon('info', 'me-2')
						span You're on the Free plan. Resource limits are configured for this account.

				table.table.table-sm.mb-4
					tbody
						tr
							th Project limit
							td= account_limits.limit_projects === 0 ? 'Unlimited' : account_limits.limit_projects
						tr
							th User limit
							td= account_limits.limit_users === 0 ? 'Unlimited' : account_limits.limit_users
						tr
							th AI workflows / day
							td= account_limits.limit_ai_workflows_per_day === 0 ? 'Unlimited' : account_limits.limit_ai_workflows_per_day

				table.table.table-sm.mb-4
					tbody
						tr
							th Plan
							td
								if isPro
									span.badge.bg-success Pro
								else if is_trialing
									span.badge.bg-info Pro trial
								else
									span.badge.bg-secondary Free
						if bu && bu.trial_ends_at && is_trialing
							tr
								th Trial ends
								td= trial_ends_text

				if isPro
					a.btn.btn-primary(href="/billing/portal")
						!= icon('gear')
						span.ms-2 Manage My Subscription
				else
					.d-flex.flex-wrap.gap-2.align-items-center
						if trial_available
							form.mb-0(action="/billing/trial" method="post")
								button.btn.btn-outline-primary(type="submit")
									!= icon('clock')
									span.ms-2 Start 7-day Pro trial
						a.btn.btn-primary(href="/billing/checkout?plan=pro")
							!= icon('creditCard')
							span.ms-2 Upgrade to Pro — $49/mo
							span.ms-2.text-decoration-line-through.opacity-75 $99
						.text-muted.fs-9.w-100 Launch pricing — locked in for as long as you stay subscribed.

				.mt-4
					h6.text-muted.text-uppercase.fs-9.mb-2 Plans
					.row.g-3
						.col-md-6
							.border.rounded.p-3.h-100
								.fw-bold.mb-1 Free
								.text-muted.small.mb-2 Core features
								ul.small.mb-0.ps-3
									li Built-in AI or bring your own key
									li Unlimited notes, memories, URLs, emails
									li Account-specific project, user, and AI limits
						.col-md-6
							.border.rounded.p-3.h-100
								.fw-bold.mb-1
									span Pro / Team — $49/mo
									span.ms-1.text-muted.text-decoration-line-through.fw-normal $99
								.text-muted.small.mb-2 Launch pricing — advanced features
								ul.small.mb-0.ps-3
									li Advanced AI model
									li Email storage and imports
									li Git Sync
									li Account limits remain independently configurable

				.mt-3.text-muted.fs-9 Streamient is made by Helpmonks LLC.
