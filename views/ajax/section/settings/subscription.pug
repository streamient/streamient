.row
	.col-md-3
		include _sidebar
	.col-md-9
		h4.mb-4 Subscription

		.card.mb-4
			.card-body
				h5.card-title
					!= icon('creditCard', 'me-2')
					| My Subscription

				- var bu = billing_user || user
				- var status = (bu && bu.subscription_status) || 'incomplete'
				- var isPro = plan === 'pro' || status === 'active'

				if isPro
					.alert.alert-success.mb-3
						!= icon('checkCircle', 'me-2')
						| Your Pro subscription is active.
				else if is_trialing
					.alert.alert-info.mb-3
						!= icon('clock', 'me-2')
						span Your 7-day Pro trial is active.
						strong.ms-1= trial_ends_text
						span .
				else if status === 'past_due'
					.alert.alert-warning.mb-3
						!= icon('warning', 'me-2')
						| Your payment is past due. Please update your payment method to keep Pro features.
				else
					.alert.alert-secondary.mb-3
						!= icon('info', 'me-2')
						| You're on the Free plan — bring your own AI key, 1 project, and up to 5 users.

				table.table.table-sm.mb-4
					tbody
						tr
							th Plan
							td
								if isPro
									span.badge.bg-success Pro
								else if is_trialing
									span.badge.bg-info Pro trial
								else
									span.badge.bg-secondary Free
						if bu && bu.trial_ends_at && is_trialing
							tr
								th Trial ends
								td= trial_ends_text

				if isPro
					a.btn.btn-primary(href="/billing/portal")
						!= icon('gear')
						span.ms-2 Manage My Subscription
				else
					.d-flex.flex-wrap.gap-2.align-items-center
						if trial_available
							form.mb-0(action="/billing/trial" method="post")
								button.btn.btn-outline-primary(type="submit")
									!= icon('clock')
									span.ms-2 Start 7-day Pro trial
						a.btn.btn-primary(href="/billing/checkout?plan=pro")
							!= icon('creditCard')
							span.ms-2 Upgrade to Pro — $99/mo

				.mt-4
					h6.text-muted.text-uppercase.fs-9.mb-2 Plans
					.row.g-3
						.col-md-6
							.border.rounded.p-3.h-100
								.fw-bold.mb-1 Free
								.text-muted.small.mb-2 Bring your own key
								ul.small.mb-0.ps-3
									li Connect your OpenAI or Gemini API key
									li Unlimited notes, memories, URLs, emails
									li 1 project
									li 5 users
						.col-md-6
							.border.rounded.p-3.h-100
								.fw-bold.mb-1 Pro / Team — $99/mo
								.text-muted.small.mb-2 Turnkey AI included
								ul.small.mb-0.ps-3
									li Managed OpenAI & Gemini models out of the box
									li Email storage and imports
									li Git Sync
									li Unlimited projects & users

				.mt-3.text-muted.fs-9 Kumbukum is made by Helpmonks LLC.
