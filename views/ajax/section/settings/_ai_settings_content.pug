h4.mb-4 AI

.card
	.card-body
		form#byo-ai-form
			.row.g-4
				.col-lg-7
					.mb-3
						label.form-label(for="byo-global-instructions") Custom AI Instructions
						textarea.form-control.form-control-sm#byo-global-instructions(
							rows="9"
							autocomplete="off"
							autocorrect="off"
							autocapitalize="off"
							spellcheck="false"
							data-instruction-scope="global"
							data-1p-ignore="true"
							data-op-ignore="true"
							data-lpignore="true"
							data-bwignore="true"
							data-form-type="other"
						)
						.form-text
							span.d-block Examples:
							span.d-block - Keep answers concise and direct.
							span.d-block - Prefer bullet points for comparisons.
							span.d-block - Use our internal product names exactly as written.
				.col-lg-5
					h6.mb-3 AI provider keys
					p.text-muted.small
						| Optional — Kumbukum's built-in AI works without any key. Add your own
						| OpenAI or Gemini key to run AI chat and search on your own account
						| instead
						if is_hosted && plan !== 'pro'
							|  (and remove the Free plan's daily AI limit)
						| .
					.mb-3
						label.form-label(for="byo-global-openai") OpenAI API key
						.input-group.input-group-sm
							input.form-control.form-control-sm#byo-global-openai(type="password" autocomplete="off" data-scope="global" data-field="openai_api_key" aria-describedby="byo-global-openai-help")
							button.btn.btn-outline-secondary(type="button" data-verify-byo="global:openai_api_key") Verify
							button.btn.btn-outline-secondary(type="button" data-clear-byo="global:openai_api_key") Clear
						.form-text#byo-global-openai-help
							span(data-status="global:openai_api_key") Loading...
					.mb-3
						label.form-label(for="byo-global-gemini") Gemini API key
						.input-group.input-group-sm
							input.form-control.form-control-sm#byo-global-gemini(type="password" autocomplete="off" data-scope="global" data-field="gemini_api_key" aria-describedby="byo-global-gemini-help")
							button.btn.btn-outline-secondary(type="button" data-verify-byo="global:gemini_api_key") Verify
							button.btn.btn-outline-secondary(type="button" data-clear-byo="global:gemini_api_key") Clear
						.form-text#byo-global-gemini-help
							span(data-status="global:gemini_api_key") Loading...
			.d-flex.justify-content-end.mt-3
				button.btn.btn-primary.btn-sm(type="submit") Save Changes
		#byo-ai-result.d-none.mt-3
