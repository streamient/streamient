.row
	.col-md-3
		include _sidebar
	.col-md-9
		h4.mb-4 Search index

		.card
			.card-body
				h5.card-title
					!= icon('search')
					span.ms-2 Reindex Search Data
				p.text-muted Rebuild the search indexes. Use this if search results seem incomplete or out of sync.
				p.text-warning.mb-4 This will temporarily disable search while the process is running.
				button.btn.btn-outline-secondary#reindex-btn(type="button")
					span.spinner-border.spinner-border-sm.me-2.d-none#reindex-btn-spinner(role="status" aria-hidden="true")
					span#reindex-btn-text Reindex All My Data
				#reindex-result.d-none.mt-4(role="status" aria-live="polite")
					.alert.alert-info.mb-0#reindex-alert
						span.spinner-border.spinner-border-sm.me-2.d-none#reindex-status-spinner(role="status" aria-hidden="true")
						span#reindex-status-message


script(src=`/static/v-${v}/js/settings_reindex.js`)
