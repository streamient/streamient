if !email_feature_enabled
	.card.border-warning-subtle
		.card-body
			h5.mb-2
				!= icon('lock', 'me-2')
				span Email Command Center (Pro)
			p.text-muted.mb-2 Hosted email command center features are available on the Pro plan.
			if is_hosted
				a.btn.btn-sm.btn-outline-warning(href="/settings/subscription") Upgrade to Pro
else
	.ecc-shell
		.ecc-left
			.mb-3
				select.form-select.form-select-sm#ecc-project-select
					option(value="") All projects
					each project in projects
						option(value=project._id.toString())= project.name
			h6.mb-2 Mailboxes
			.list-group.mb-4#ecc-mailboxes
				button.list-group-item.list-group-item-action.d-flex.align-items-center.active(type="button" data-mailbox="inbox")
					!= icon('email', 'me-2')
					span Inbox
					span.badge.text-bg-secondary.ms-auto 0
				button.list-group-item.list-group-item-action.d-flex.align-items-center(type="button" data-mailbox="drafts")
					!= icon('draft', 'me-2')
					span Drafts
					span.badge.text-bg-secondary.ms-auto 0
				button.list-group-item.list-group-item-action.d-flex.align-items-center(type="button" data-mailbox="archived")
					!= icon('archive', 'me-2')
					span Archived
					span.badge.text-bg-secondary.ms-auto 0
				button.list-group-item.list-group-item-action.d-flex.align-items-center(type="button" data-mailbox="sent")
					!= icon('send', 'me-2')
					span Sent
					span.badge.text-bg-secondary.ms-auto 0
				button.list-group-item.list-group-item-action.d-flex.align-items-center(type="button" data-mailbox="spam")
					!= icon('warning', 'me-2')
					span Spam
					span.badge.text-bg-secondary.ms-auto 0
				button.list-group-item.list-group-item-action.d-flex.align-items-center(type="button" data-mailbox="trash")
					!= icon('delete', 'me-2')
					span Trash
					span.badge.text-bg-secondary.ms-auto 0
			#ecc-labels
				.ecc-label-section(data-label-section="actions")
					h6.mb-2 Actions
					.list-group
						button.list-group-item.list-group-item-action.d-flex.align-items-center(type="button" data-label="reply-required")
							span.ecc-label-dot.me-2(style="background:#dc3545")
							span.ecc-label-name.text-truncate Review
							span.badge.text-bg-secondary.ms-auto 0
						button.list-group-item.list-group-item-action.d-flex.align-items-center(type="button" data-label="human-do")
							span.ecc-label-dot.me-2(style="background:#fd7e14")
							span.ecc-label-name.text-truncate Human Do
							span.badge.text-bg-secondary.ms-auto 0
						button.list-group-item.list-group-item-action.d-flex.align-items-center(type="button" data-label="waiting")
							span.ecc-label-dot.me-2(style="background:#0d6efd")
							span.ecc-label-name.text-truncate Waiting
							span.badge.text-bg-secondary.ms-auto 0
						button.list-group-item.list-group-item-action.d-flex.align-items-center(type="button" data-label="marketing")
							span.ecc-label-dot.me-2(style="background:#6f42c1")
							span.ecc-label-name.text-truncate Marketing
							span.badge.text-bg-secondary.ms-auto 0
				.ecc-label-section(data-label-section="status")
					h6.mb-2 Status
					.list-group
						button.list-group-item.list-group-item-action.d-flex.align-items-center(type="button" data-label="spam")
							span.ecc-label-dot.me-2(style="background:#212529")
							span.ecc-label-name.text-truncate Spam
							span.badge.text-bg-secondary.ms-auto 0
						button.list-group-item.list-group-item-action.d-flex.align-items-center(type="button" data-label="no-action")
							span.ecc-label-dot.me-2(style="background:#6c757d")
							span.ecc-label-name.text-truncate No action
							span.badge.text-bg-secondary.ms-auto 0
		.ecc-main
			.d-flex.justify-content-between.align-items-center.mb-3#ecc-view-header
				.d-flex.align-items-center.gap-2
					button.btn.btn-outline-secondary.btn-sm#ecc-select-all-btn.d-none(type="button" title="Select all visible emails" aria-pressed="false")
						span#ecc-select-all-text Select all
					.d-none.align-items-center.flex-wrap.gap-2#ecc-action-bar
						span.badge.text-bg-secondary#ecc-action-count 0 selected
						span.ecc-select-all-across.small.d-none#ecc-select-all-across
							a.ecc-select-all-across-link(href="#" id="ecc-select-all-across-link")
						.d-flex.align-items-center.flex-wrap.gap-2#ecc-move-actions
						button.btn.btn-outline-secondary.btn-sm#ecc-reset-triage-btn(type="button")
							span Reset triage
						button.btn.btn-outline-danger.btn-sm#ecc-trash-btn(type="button")
							span.ecc-trash-text Trash
				.d-flex.align-items-center.gap-2
					button.btn.btn-primary.btn-sm#ecc-triage-btn(type="button")
						!= icon('sparkle', 'me-1')
						span Triage Inbox
					button.btn.btn-outline-secondary.btn-sm#ecc-refresh-btn(type="button" title="Refresh")
						!= icon('sync')
			.d-flex.justify-content-between.align-items-center.mb-2.d-none#ecc-trash-toolbar
				.trash-hint.text-muted.small
					!= icon('info', 'me-1')
					| Items in trash are automatically deleted after 30 days.
				button.btn.btn-outline-danger.btn-sm#ecc-empty-trash-btn(type="button")
					!= icon('delete', 'me-1')
					| Empty Trash
			.d-flex.justify-content-between.align-items-center.mb-2.d-none#ecc-spam-toolbar
				.spam-hint.text-muted.small
					!= icon('info', 'me-1')
					span Items in spam are automatically deleted after 30 days.
				button.btn.btn-outline-danger.btn-sm#ecc-empty-spam-btn(type="button")
					!= icon('delete', 'me-1')
					span Empty Spam
			#ecc-list-wrap
				#ecc-list.list-group
			#ecc-detail.d-none
				.d-flex.justify-content-between.align-items-start.mb-3.pt-3
					.d-flex.align-items-start.min-w-0.flex-grow-1.w-100
						button.btn.btn-outline-secondary.btn-sm.me-3#ecc-detail-back-btn(type="button" title="Back to list")
							!= icon('arrowBack')
						div.min-w-0.flex-grow-1
							h5.mb-1.text-truncate#ecc-detail-title Email detail
							.d-flex.justify-content-between.align-items-center.gap-3
								p.text-muted.small.mb-0.text-truncate#ecc-detail-subtitle Loading thread.
								.d-flex.align-items-center.flex-shrink-0
									span.badge.text-bg-secondary.me-3.d-none#ecc-detail-mailbox-status
									small.text-muted.text-nowrap.text-end#ecc-detail-date
				#ecc-detail-actions.d-flex.flex-wrap.align-items-center.gap-2.mb-3
				#ecc-detail-status.ecc-email-status.mb-3
				#ecc-detail-draft.mb-3
				#ecc-detail-thread
		.ecc-ai
			#ecc-ai-panel.ecc-ai-panel
				.ecc-ai-empty
					!= icon('sparkle', 'mb-2')
					h6.mb-2 AI idle
					p.text-muted.small.mb-0 Email selection will not start AI.
			#ecc-internal-notes.ecc-internal-notes.d-none
