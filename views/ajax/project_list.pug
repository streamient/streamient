each p in projects
	- const pc = counts[p._id.toString()] || { notes: 0, memory: 0, urls: 0, emails: 0 }
	.card.project-item.mb-3.position-relative(data-id=p._id class=(p._id.toString() === activeProjectId ? 'active' : ''))
		.project-drop-overlay.d-none
			.project-drop-overlay-inner
				!= icon('uploadCloud')
				span Upload as notes
		.card-body.p-0
			.d-flex.align-items-center.py-2.ps-2.p-3.bg-hover-light.project-item-name-row
				span.project-color(style=`background:${p.color}`)
				span.project-item-name #{p.name}
				button.project-settings-gear(type="button" title="Open project" onclick=`event.stopPropagation(); setActiveProject('${p._id}'); navigateTo('/dashboard')`)
					!= icon('moreHoriz')
			.d-flex.align-items-center.py-1.pe-3.bg-hover-light.project-item-section.position-relative
				a.stretched-link(href="/notes")
				.pe-2.section-link
					span Notes
				.ms-auto.section-link
					span.section-count= pc.notes
			.d-flex.align-items-center.py-1.pe-3.bg-hover-light.project-item-section.position-relative
				a.stretched-link(href="/memories")
				.pe-2.section-link
					span Memories
				.ms-auto.section-link
					span.section-count= pc.memory
			.d-flex.align-items-center.py-1.pe-3.bg-hover-light.project-item-section.position-relative
				a.stretched-link(href="/urls")
				.pe-2.section-link
					span URLs
				.ms-auto.section-link
					span.section-count= pc.urls
			.d-flex.align-items-center.py-1.pe-3.bg-hover-light.project-item-section.position-relative
				a.stretched-link(href="/emails")
				.pe-2.section-link
					span Emails
				.ms-auto.section-link
					span.section-count= pc.emails
