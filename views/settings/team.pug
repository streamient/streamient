extends layout

block settings
	#team-page(data-can-manage-team=can_manage_team ? 'true' : 'false' data-user-id=user._id.toString())
		h4.mb-4 My Team
		if !can_manage_team
			.alert.alert-warning
				!= icon('shieldWarning', 'me-2')
				| Team admin access is required to manage members for this account.
		else
			if is_hosted && !projects_unlimited
				.alert.alert-info.d-flex.align-items-center.mb-4
					!= icon('users', 'me-2')
					div
						strong Free plan: up to 5 users.
						a.ms-1(href="/settings/subscription") Upgrade to unlimited users
			.row.g-4
				.col-lg-5
					.card.mb-4
						.card-body
							h5.card-title.mb-3
								!= icon('userAdd', 'me-2')
								| Add teammate
							form#team-member-form
								.mb-3
									label.form-label(for="team-member-name") Name
									input.form-control.form-control-sm#team-member-name(type="text" required autocomplete="name")
								.mb-3
									label.form-label(for="team-member-email") Email
									input.form-control.form-control-sm#team-member-email(type="email" required autocomplete="email")
								.mb-3
									label.form-label(for="team-member-password") Password
									input.form-control.form-control-sm#team-member-password(type="password" required minlength="8" autocomplete="new-password")
								.form-check.mb-3
									input.form-check-input#team-member-send-welcome(type="checkbox" checked)
									label.form-check-label(for="team-member-send-welcome") Send welcome email
								.text-end
									button.btn.btn-primary.btn-sm(type="submit") Add user
				.col-lg-7
					.card
						.card-body
							h5.card-title.mb-3
								!= icon('users', 'me-2')
								| Members
							#team-members-list.text-muted Loading team members…

block scripts
	if can_manage_team
		script(src=`/static/v-${v}/js/team.js`)
