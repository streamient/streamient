extends layout

block settings
	h4.mb-4 BYO AI

	.card
		.card-body
			form#byo-ai-form
				.row.g-4
					.col-md-6
						h5.mb-3 Global
						p.text-muted.small Used for general AI chat and search.
						.mb-3
							label.form-label(for="byo-global-openai") OpenAI API key
							.input-group
								input.form-control#byo-global-openai(type="password" autocomplete="off" placeholder="Leave blank to keep current key" data-scope="global" data-field="openai_api_key")
								button.btn.btn-outline-secondary(type="button" data-clear-byo="global:openai_api_key") Clear
							.form-text(data-status="global:openai_api_key") Loading...
						.mb-3
							label.form-label(for="byo-global-gemini") Gemini API key
							.input-group
								input.form-control#byo-global-gemini(type="password" autocomplete="off" placeholder="Leave blank to keep current key" data-scope="global" data-field="gemini_api_key")
								button.btn.btn-outline-secondary(type="button" data-clear-byo="global:gemini_api_key") Clear
							.form-text(data-status="global:gemini_api_key") Loading...
						.mb-3
							label.form-label(for="byo-global-instructions") Global AI instructions
							textarea.form-control.form-control-sm#byo-global-instructions(
								rows="5"
								autocomplete="off"
								autocorrect="off"
								autocapitalize="off"
								spellcheck="false"
								data-instruction-scope="global"
								data-1p-ignore="true"
								data-op-ignore="true"
								data-lpignore="true"
								data-bwignore="true"
								data-form-type="other"
							)
					.col-md-6
						h5.mb-3 Email
						p.text-muted.small Used only when a prompt is explicitly scoped to emails.
						.mb-3
							label.form-label(for="byo-email-openai") OpenAI API key
							.input-group
								input.form-control#byo-email-openai(type="password" autocomplete="off" placeholder="Leave blank to keep current key" data-scope="email" data-field="openai_api_key")
								button.btn.btn-outline-secondary(type="button" data-clear-byo="email:openai_api_key") Clear
							.form-text(data-status="email:openai_api_key") Loading...
						.mb-3
							label.form-label(for="byo-email-gemini") Gemini API key
							.input-group
								input.form-control#byo-email-gemini(type="password" autocomplete="off" placeholder="Leave blank to keep current key" data-scope="email" data-field="gemini_api_key")
								button.btn.btn-outline-secondary(type="button" data-clear-byo="email:gemini_api_key") Clear
							.form-text(data-status="email:gemini_api_key") Loading...
						.mb-3
							label.form-label(for="byo-email-instructions") Email AI instructions
							textarea.form-control.form-control-sm#byo-email-instructions(
								rows="5"
								autocomplete="off"
								autocorrect="off"
								autocapitalize="off"
								spellcheck="false"
								data-instruction-scope="email"
								data-1p-ignore="true"
								data-op-ignore="true"
								data-lpignore="true"
								data-bwignore="true"
								data-form-type="other"
							)
						.mb-3
							label.form-label(for="byo-email-triage-instructions") Email triage instructions
							textarea.form-control.form-control-sm#byo-email-triage-instructions(
								rows="5"
								autocomplete="off"
								autocorrect="off"
								autocapitalize="off"
								spellcheck="false"
								data-instruction-scope="email_triage"
								data-1p-ignore="true"
								data-op-ignore="true"
								data-lpignore="true"
								data-bwignore="true"
								data-form-type="other"
							)
				button.btn.btn-primary(type="submit") Save Changes
			#byo-ai-result.d-none.mt-3

block scripts
	include ../ajax/section/settings/_byo_ai_script
