extends layout

block sidebar
	//- No sidebar on graph page

block chat
	//- No chat sidebar on graph page

block head
	style.
		html, body.kk-template1 { height: 100%; overflow: hidden; }
		#sidebar { display: none !important; }
		#chat-sidebar { display: none !important; }
		#chat-results-panel { display: none !important; }
		#main-content {
			margin-left: 0 !important;
			max-width: 100% !important;
			width: 100% !important;
			overflow: hidden !important;
		}
		#page-content {
			flex: 1 1 0;
			min-height: 0;
			display: flex;
			flex-direction: column;
		}
		.graph-toolbar { flex-shrink: 0; }
		.graph-wrapper {
			flex: 1 1 0;
			min-height: 0;
			display: flex;
			gap: 12px;
		}
		.graph-main {
			flex: 1 1 0;
			min-width: 0;
			position: relative;
		}
		#graph-container {
			width: 100%;
			height: 100%;
			border: 1px solid var(--kk-line, var(--bs-border-color));
			border-radius: 12px;
			background: var(--kk-bg, var(--bs-body-bg));
		}
		#graph-info-panel {
			flex: 0 0 260px;
			overflow-y: auto;
			border: 1px solid var(--kk-line, var(--bs-border-color));
			border-radius: 12px;
			background: var(--kk-panel);
			color: var(--kk-text);
			padding: 12px;
		}
		.graph-legend-dot {
			display: inline-block;
			width: 12px;
			height: 12px;
			border-radius: 50%;
			margin-right: 4px;
			vertical-align: middle;
		}

block content
	.graph-toolbar.d-flex.justify-content-between.align-items-center.mb-3
		.d-flex.align-items-center.gap-3
			h5.mb-0 Knowledge Graph
			.input-group.input-group-sm(style="width:200px")
				span.input-group-text
					!= icon('search')
				input.form-control.form-control-sm#graph-search(type="text" placeholder="Search nodes...")
		.d-flex.gap-2.align-items-center
			.btn-group.btn-group-sm(role="group")
				button.btn.btn-outline-primary.active#toggle-manual(type="button" title="Manual links")
					!= icon('link', 'me-1')
					| Links
				button.btn.btn-outline-success.active#toggle-tags(type="button" title="Shared tag connections")
					!= icon('tag', 'me-1')
					| Tags
				button.btn.btn-outline-warning#toggle-semantic(type="button" title="AI similarity connections")
					!= icon('sparkle', 'me-1')
					| Semantic
			select.form-select.form-select-sm#graph-project-filter(style="width:auto")
				option(value="") All projects
				each p in projects
					option(value=p._id)= p.name

	.graph-wrapper
		.graph-main
			.alert.alert-info.py-2.px-3.mb-2.small.d-none#graph-status
			#graph-container
			#graph-loading.position-absolute.top-0.start-0.w-100.h-100.d-flex.align-items-center.justify-content-center(style="background:var(--bg, var(--bs-body-bg));z-index:10;border-radius:12px")
				.text-center
					.spinner-border.text-primary(role="status")
						span.visually-hidden Loading...
					p.text-muted.small.mt-2 Loading graph…
		#graph-info-panel
			.text-muted.small.text-center.py-5
				!= icon('cursor', 'd-block fs-3 mb-2')
				| Click a node to see details

			//- Legend
			.mt-4.border-top.pt-3
				h6.small.text-muted.mb-2 Legend
				.d-flex.flex-column.gap-1.small
					div
						span.graph-legend-dot(style="background:#4A90D9")
						| Notes
					div
						span.graph-legend-dot(style="background:#50C878")
						| Memories
					div
						span.graph-legend-dot(style="background:#E8943A")
						| URLs
				.mt-2.d-flex.flex-column.gap-2.small
					div
						span.text-muted — 
						| Manual link
						p.text-muted.mb-0(style="font-size:.7rem") Connections you created yourself between items
					div
						span.text-muted - - 
						| Shared tag
						p.text-muted.mb-0(style="font-size:.7rem") Items linked because they share the same tag
					div
						span.text-muted ··· 
						| Semantic similarity
						p.text-muted.mb-0(style="font-size:.7rem") AI-detected connections between items with similar meaning

	script(type="module" src=`/static/v-${v}/js/graph_bundle.js`)
	script(src=`/static/v-${v}/js/graph.js` defer)
