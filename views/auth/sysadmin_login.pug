extends ../auth_layout

block head
	title Sysadmin Login — Kumbukum

block body
	h1.h2.mb-2 Sysadmin Login
	p.text-muted.mb-5 Select an account to sign in to.
	.mb-3
		label.form-label(for="account-search") Account search
		.position-relative
			input.form-control.form-control-sm#account-search(type="text" autocomplete="off")
			.list-group.position-absolute.w-100.shadow-sm.d-none#search-results(style="z-index:1050; max-height:300px; overflow-y:auto")
	hr.my-4
	button.btn.btn-primary.btn-sm.w-100#sign-in-own(type="button")
		!= icon('signIn', 'me-2')
		span Sign in to my account

block scripts
	script(src=`/static/v-${v}/js/sysadmin_login.js`)
