extends ../auth_layout

block head
	title Password Reset — Kumbukum

block body
	.container
		.row.justify-content-center.mt-5
			.col-md-5.my-auto
				.card.shadow
					.card-body
						.text-center.logo-form
							.mb-5
								include ../includes/white_label_auth_logo

						if error
							.alert.alert-danger= error
							.text-center.mt-3
								a(href="/forgot-password") Try again

						else
							h3.mb-5 Your new password
							.text-center.border.p-3.mb-2
								h4.mb-0.font-monospace.user-select-all#new-password= password
							.text-muted.text-center.small.fs-7 Copy this password and use it to sign in. You can change it later in your security settings.

							form(action="/reset-password/confirm" method="POST")
								input(type="hidden" name="token" value=token)
								button.btn.btn-primary.w-100(type="submit") Continue to Login
