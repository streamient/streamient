extends ../auth_layout

block head
	title Password Reset — Kumbukum

block body
	if error
		h1.h2.mb-2 Password reset
		.alert.alert-danger= error
		.mt-4
			a(href="/forgot-password") Try again
	else
		h1.h2.mb-2 Your new password
		p.text-muted.mb-4 Copy this password and use it to sign in.
		.text-center.border.rounded.p-3.mb-3
			h4.mb-0.font-monospace.user-select-all#new-password= password
		p.text-muted.small.mb-4 You can change it later in your security settings.
		form(action="/reset-password/confirm" method="POST")
			input(type="hidden" name="token" value=token)
			button.btn.btn-primary.btn-sm.w-100(type="submit") Continue to Login
