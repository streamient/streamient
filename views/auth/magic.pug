extends ../auth_layout

block head
	title Magic Link Login — Kumbukum

block body
	.container
		.row.justify-content-center.mt-5
			.col-md-5.my-auto
				.card.shadow
					.card-body
						.text-center.logo-form
							.mb-5
								include ../includes/white_label_auth_logo

						if error
							.alert.alert-danger= error
							.mt-3.text-center
								a(href="/login") Back to login
						else
							h3.mb-4 Continue login
							p.text-muted.mb-4 This step confirms it is really you before we sign you in.
							form(method="POST" action="/magic")
								input(type="hidden" name="token" value=token)
								button.btn.btn-primary.w-100(type="submit") Continue to dashboard

block scripts
	script(src=`/static/v-${v}/js/vendor.js` type="module")
