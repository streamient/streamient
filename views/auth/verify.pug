extends ../auth_layout

block head
	title Confirm Your Account — Kumbukum

block body
	if error
		h1.h2.mb-2 Confirm account
		.alert.alert-danger= error
		.mt-4
			a(href="/signup") Sign up again
	else
		h1.h2.mb-2 Confirm your account
		p.text-muted.mb-5 Activate your Kumbukum account.
		form(method="POST" action="/verify")
			input(type="hidden" name="token" value=token)
			button.btn.btn-primary.btn-sm.w-100(type="submit") Yes, activate my account

block scripts
	script(src=`/static/v-${v}/js/vendor.js` type="module")
