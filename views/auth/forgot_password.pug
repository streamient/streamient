extends ../auth_layout

block head
	title Forgot Password — Streamient

block body
	form#forgot-password-form
		h1.h2.mb-2 Reset password
		p.text-muted.mb-5 Enter your email to reset your password.
		.mb-3
			label.form-label(for="email") Email
			input.form-control.form-control-sm#email(type="email" name="email" required autofocus)
		button.btn.btn-primary.btn-sm.w-100(type="submit") Send Reset Link
	.mt-5
		a(href="/login") Back to login

block scripts
	script(src=`/static/v-${v}/js/vendor.js` type="module")
	script(src=`/static/v-${v}/js/auth.js`)
