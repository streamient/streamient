doctype html
html(lang="en")
	head
		meta(charset="UTF-8")
		meta(name="viewport" content="width=device-width, initial-scale=1")
		title #{title || 'Kumbukum'}
		- const __wlFavicon = typeof white_label !== 'undefined' && white_label && white_label.favicon_url ? white_label.favicon_url : '/static/images/favicon.ico'
		link(href=__wlFavicon rel="shortcut icon")
		if !(typeof white_label !== 'undefined' && white_label && white_label.favicon_url)
			link(href="/static/images/favicon.svg" rel="icon" type="image/svg+xml")
			link(href="/static/images/apple-touch-icon.png" rel="apple-touch-icon" sizes="180x180")
		script.
			(function () {
				try {
					var t = localStorage.getItem('kk-theme');
					if (t !== 'light' && t !== 'dark') t = 'dark';
					document.documentElement.setAttribute('data-theme', t);
					document.documentElement.setAttribute('data-bs-theme', t);
				} catch (e) {
					document.documentElement.setAttribute('data-theme', 'dark');
					document.documentElement.setAttribute('data-bs-theme', 'dark');
				}
			})();
		script(type="importmap").
			{ "imports": { "/static/js/vendor.js": "/static/v-#{v}/js/vendor.js" } }
		link(href=`/static/v-${v}/css/admin_vendor.css` rel="stylesheet")
		link(href=`/static/v-${v}/css/app.css` rel="stylesheet")
		link(href=`/static/v-${v}/css/kumbukum-tabler.css` rel="stylesheet")
		block head
	body.kk-template1(class=((hide_chat_sidebar || page === 'graph') ? 'kk-no-chat-sidebar ' : ''))
		block body
			include includes/avatar
			if impersonating
				.alert.alert-warning.text-center.mb-0.rounded-0.py-1(style="position:sticky;top:0;z-index:1060")
					!= icon('shieldWarning', 'me-2')
					strong Sysadmin
					|  — viewing as #{impersonatingName}
					button.btn.btn-sm.btn-outline-dark.ms-3#exit-impersonation Exit

			aside.navbar.navbar-vertical.navbar-expand-lg.kk-app-sidebar#sidebar
				.container-fluid
					button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#sidebar-menu" aria-controls="sidebar-menu" aria-expanded="false" aria-label="Toggle navigation")
						span.navbar-toggler-icon
					h1.navbar-brand.navbar-brand-autodark.mb-0
						a.d-flex.align-items-center(href="/dashboard" aria-label="Kumbukum")
							- const __wlSidebarLogo = typeof white_label !== 'undefined' && white_label && white_label.logo_url ? white_label.logo_url : ''
							if __wlSidebarLogo
								img.kk-white-label-navbar-logo(src=__wlSidebarLogo alt="Logo")
							else
								span.kk-logo-dark
									include includes/logo_white
								span.kk-logo-light
									include includes/logo_black
					.collapse.navbar-collapse.flex-column.align-items-stretch.flex-grow-1#sidebar-menu
						.kk-sidebar-body
							block sidebar
								if projects_unlimited
									.d-flex.justify-content-between.align-items-center.mb-3
										h6.mb-0 My Projects
										button.btn.btn-sm.btn-outline-primary#new-project-btn(title="New project")
											!= icon('add')
								#project-list

								if !projects_unlimited && is_hosted
									a.d-block.text-center.small.my-3.text-primary(href="/settings/subscription") Need unlimited projects?

								a.kk-sidebar-trash.d-flex.align-items-center.text-decoration-none.text-muted.small(href="/trash")
									!= icon('delete')
									span.ms-2 Global Trash
									span.ms-auto.d-none#trash-count-badge

			main.page-wrapper#main-content
				header.navbar.navbar-expand-md.d-print-none.kk-topbar
					.container-fluid
						.kk-navbar-left.d-flex.align-items-center.gap-2.min-w-0
							button.btn.btn-icon.btn-ghost-secondary.d-lg-none(type="button" data-bs-toggle="collapse" data-bs-target="#sidebar-menu" aria-controls="sidebar-menu" aria-expanded="false" aria-label="Toggle navigation")
								span.navbar-toggler-icon
							//- The sidebar (and its logo) is hidden on the graph page, so carry the brand in the topbar there
							if page === 'graph'
								a.kk-topbar-brand.d-flex.align-items-center.me-2(href="/dashboard" aria-label="Kumbukum")
									- const __wlTopbarLogo = typeof white_label !== 'undefined' && white_label && white_label.logo_url ? white_label.logo_url : ''
									if __wlTopbarLogo
										img.kk-white-label-navbar-logo(src=__wlTopbarLogo alt="Logo")
									else
										span.kk-logo-dark
											include includes/logo_white
										span.kk-logo-light
											include includes/logo_black
							nav.kk-topnav
								a.kk-navbtn(href="/dashboard" class={active: page !== 'graph'}) Projects
								a.kk-navbtn(href="/graph" class={active: page === 'graph'}) Graph
						.kk-global-search
							button.kk-global-search-trigger#kk-global-search-trigger(type="button" aria-haspopup="dialog" aria-controls="kk-search-palette")
								!= icon('search', 'kk-global-search-icon')
								span.kk-global-search-text Type
								kbd /
								span.kk-global-search-text to search
								span.kk-global-search-spacer
						.ms-auto.d-flex.align-items-center.kk-navbar-actions
							if user
								if is_trialing
									a.btn.btn-warning.btn-sm.me-3(href="/settings/subscription")
										!= icon('creditCard', 'me-1')
										span= trial_ends_text || 'Trial'
								else if trial_available
									form.me-3.mb-0(action="/billing/trial" method="post")
										button.btn.btn-warning.btn-sm(type="submit")
											!= icon('creditCard', 'me-1')
											span Start 7-day Pro trial
								else if can_upgrade
									a.btn.btn-outline-warning.btn-sm.me-3(href="/settings/subscription")
										!= icon('creditCard', 'me-1')
										span Upgrade to Pro
								if accessible_tenants && accessible_tenants.length > 1
									.dropdown.me-2
										button.btn.btn-outline-secondary.btn-sm.dropdown-toggle.d-flex.align-items-center.gap-1(type="button" data-bs-toggle="dropdown")
											!= icon('apartment')
											span= active_tenant ? active_tenant.name : 'Select account'
										ul.dropdown-menu.dropdown-menu-end
											each tenant in accessible_tenants
												li
													- var isCurrentTenant = active_tenant && tenant.tenantId === active_tenant.tenantId
													a.dropdown-item.account-switch-link(href="#" data-tenant-id=tenant.tenantId class=(isCurrentTenant ? 'is-current' : '') aria-current=(isCurrentTenant ? 'true' : undefined) tabindex=(isCurrentTenant ? '-1' : undefined))
														.d-flex.justify-content-between.align-items-center.gap-3
															span= tenant.name
															span.kk-account-role-badge= tenant.role
								.dropdown
									button.btn.btn-outline-secondary.btn-sm.dropdown-toggle.d-flex.align-items-center.gap-1(type="button" data-bs-toggle="dropdown")
										+avatar(user.name, 'xs')
										span= user.name
									ul.dropdown-menu.dropdown-menu-end
										li: a.dropdown-item(href="/settings/profile") Profile & Settings
										li: hr.dropdown-divider
										li: a.dropdown-item(href="/docs" target="_blank") Guides & Help
										li: a.dropdown-item(href="/api/doc" target="_blank") API Docs
										li: hr.dropdown-divider
										li: a.dropdown-item(href="/docs/guide/browser-extension" target="_blank") Browser Extension
										if is_hosted
											li: hr.dropdown-divider
											li: a.dropdown-item(href="/settings/subscription") My Subscription
										li: hr.dropdown-divider
										li
											a.dropdown-item#theme-toggle(href="#" role="button")
												span.kk-theme-label-dark Light theme
												span.kk-theme-label-light Dark theme
										li: hr.dropdown-divider
										li: a.dropdown-item(href="#" onclick="logout()") Logout

				.page-body.kk-page-body
					.container-fluid.kk-page-container
						.kk-content-grid
							.kk-content-main
								#chat-results-panel.d-none.mb-4
									.d-flex.justify-content-between.align-items-center.mb-3
										h6.mb-0
											!= icon('search', 'me-1')
											| Chat Results
										button.btn.btn-sm.btn-outline-secondary#close-chat-results(title="Close results")
											!= icon('close')
									#chat-results-list
								#page-content
									block content

							aside.kk-chat-rail#chat-sidebar
								block chat
									include includes/chat_sidebar

		#kk-search-backdrop.kk-search-backdrop.d-none
		#kk-search-palette.kk-search-palette.d-none(role="dialog" aria-modal="true" aria-labelledby="kk-search-title")
			.kk-search-dialog
				.kk-search-input-row
					!= icon('search', 'kk-search-input-icon')
					label.visually-hidden(for="kk-search-input") Search
					input.form-control.form-control-sm#kk-search-input(type="search" autocomplete="off" autocapitalize="off" spellcheck="false" aria-describedby="kk-search-help")
					kbd Esc
				#kk-search-help.kk-search-help Search everything
				#kk-search-results.kk-search-results(role="listbox" aria-label="Search results")
				.kk-search-footer
					span
						kbd Up
						kbd Down
						span Navigate
					span
						kbd Enter
						span Open

		//- Universal modal for viewing/editing/creating items
		.modal.fade#chat-result-modal(tabindex="-1" aria-hidden="true")
			.modal-dialog.modal-xl
				.modal-content
					.modal-header
						span.badge.me-2#result-modal-badge
						h5.modal-title#result-modal-title
						button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
					.modal-body#result-modal-body
						//- Note form
						#result-modal-note.d-none
							.mb-3
								.form-text Title
								input.form-control#rm-note-title(type="text")
							.mb-3
								.form-text Tags
								input.form-control#rm-note-tags(type="text")
							ul.nav.nav-tabs.mb-3
								li.nav-item
									button.nav-link.active#rm-note-tab-preview(type="button") Preview
								li.nav-item
									button.nav-link#rm-note-tab-edit(type="button") Edit
							#rm-note-preview.preview-container.border.border-top-0.rounded-bottom.p-3.mb-3(style="min-height:300px")
							#rm-note-editor.border-0.rounded.p-0.d-none.mb-3(style="min-height:300px")
							.mb-3.position-relative
								.form-text Links
								.source-search-wrap
									!= icon('search', 'source-search-icon')
									input.form-control.rm-link-search(type="text" placeholder="Type to search..." autocomplete="off")
								.rm-link-tags.d-flex.flex-wrap.gap-1.mt-2

						//- Memory form
						#result-modal-memory.d-none
							.mb-3
								.form-text Title
								input.form-control#rm-memory-title(type="text")
							.mb-3
								.form-text Tags
								input.form-control#rm-memory-tags(type="text")
							.mb-3
								.form-text Source
								input.form-control#rm-memory-source(type="text")
							ul.nav.nav-tabs.mb-3
								li.nav-item
									button.nav-link.active#rm-memory-tab-preview(type="button") Preview
								li.nav-item
									button.nav-link#rm-memory-tab-edit(type="button") Edit
							#rm-memory-preview.preview-container.border.border-top-0.rounded-bottom.p-3.mb-3(style="min-height:300px")
							#rm-memory-editor.border-0.rounded.p-0.d-none.mb-3(style="min-height:300px")
							.mb-3.position-relative
								.form-text Links
								.source-search-wrap
									!= icon('search', 'source-search-icon')
									input.form-control.rm-link-search(type="text" placeholder="Type to search..." autocomplete="off")
								.rm-link-tags.d-flex.flex-wrap.gap-1.mt-2

						//- URL form
						#result-modal-url.d-none
							ul.nav.nav-tabs.mb-3.px-3
								li.nav-item
									button.nav-link.active#rm-url-tab-details(type="button") Details
								li.nav-item
									button.nav-link.d-none#rm-url-tab-pages(type="button")
										| Crawled pages
										span.badge.rounded-pill.ms-2#rm-url-tab-pages-count 0
							#rm-url-pane-details
								.d-flex.mb-3.w-100.px-3
									.d-none.pe-5.pt-4#rm-url-og-wrap
										img.rounded#rm-url-og-image(alt="" style="object-fit:cover")
									.flex-grow-1
										.mb-3
											.d-flex.justify-content-between.align-items-center
												.form-text URL
												a.form-text.text-decoration-none.d-none#rm-url-visit-link(href="#" target="_blank" rel="noopener")
													span Visit
											input.form-control#rm-url-input(type="url" autofocus)
										.mb-3
											.form-text Title (optional)
											input.form-control#rm-url-title(type="text")
										.mb-4
											.form-text Description (optional)
											textarea.form-control#rm-url-description(type="text" rows="3")
										.mb-3.form-check
											input.form-check-input#rm-url-crawl(type="checkbox")
											label.form-check-label(for="rm-url-crawl") Enable URL path crawling
											.text-muted.fs-9 Index this URL and pages under its path
										//- .mb-3.d-none#rm-url-crawl-wrap
										//- 	.form-text Crawled pages
										//- 	.small.text-muted.mb-2#rm-url-crawl-meta
								.mb-3.px-3.position-relative
									.form-text Links (optional)
									.source-search-wrap
										!= icon('search', 'source-search-icon')
										input.form-control.rm-link-search(type="text" placeholder="Type to search..." autocomplete="off")
									.rm-link-tags.d-flex.flex-wrap.gap-1.mt-2
							#rm-url-pane-pages.d-none.px-3.pb-2
								.d-flex.justify-content-between.align-items-center.mb-2
									.small.text-muted Crawled page URLs (opens in new tab)
									.d-flex.gap-2
										button.btn.btn-sm.btn-outline-secondary(type="button")#rm-url-resync-btn
											!= icon('sync', 'me-1')
											| Resync now
										button.btn.btn-sm.btn-outline-danger(type="button")#rm-url-delete-pages-btn
											!= icon('delete', 'me-1')
											| Delete pages
								.list-group#rm-url-crawl-list
								button.btn.btn-sm.btn-outline-secondary.mt-2.d-none(type="button")#rm-url-crawl-load-more-btn Load more

						//- Email details (read-only)
						#result-modal-email.d-none
							ul.nav.nav-tabs.mb-3.px-3
								li.nav-item
									button.nav-link.active#rm-email-tab-details(type="button") Details
								li.nav-item
									button.nav-link#rm-email-tab-body(type="button") Body
							#rm-email-pane-details.px-3
								.row.g-3
										.col-md-8#rm-email-main-col
										.mb-2
											.form-text Subject
											input.form-control#rm-email-subject(type="text" readonly)
										.mb-2
											.form-text From
											input.form-control#rm-email-from(type="text" readonly)
										.mb-2
											.form-text To
											input.form-control#rm-email-to(type="text" readonly)
										.mb-2
											.form-text Cc
											input.form-control#rm-email-cc(type="text" readonly)
										.mb-2
											.form-text Bcc
											input.form-control#rm-email-bcc(type="text" readonly)
										.mb-2
											.form-text Message ID
											textarea.form-control#rm-email-message-id(rows="2" readonly)
										.mb-2
											.form-text References
											textarea.form-control#rm-email-references(rows="3" readonly)
										.col-md-4.d-none#rm-email-thread-col
										.form-text Thread
											#rm-email-thread.small
							#rm-email-pane-body.d-none.px-3.pb-2
								.d-flex.justify-content-between.align-items-center.mb-2
									.form-text Body
									.d-flex.align-items-center.gap-2.kk-email-body-controls
										.btn-group.btn-group-sm#rm-email-body-mode(role="group" aria-label="Email body mode")
											button.btn.btn-outline-secondary.active#rm-email-html-btn(type="button")
												span HTML
											button.btn.btn-outline-secondary#rm-email-text-btn(type="button")
												span Text
										.btn-group.btn-group-sm.mx-2#rm-email-theme-mode(role="group" aria-label="Email HTML theme")
											button.btn.btn-outline-secondary.active#rm-email-dark-btn(type="button")
												span Dark
											button.btn.btn-outline-secondary#rm-email-original-btn(type="button")
												span Original
										button.btn.btn-outline-secondary.btn-sm.d-none#rm-email-load-images-btn(type="button")
											span Load images
								#rm-email-content.preview-container.border.rounded.p-0(style="min-height:220px")
									iframe#rm-email-html-frame.d-none(title="Email HTML body" sandbox="allow-scripts allow-popups allow-popups-to-escape-sandbox" referrerpolicy="no-referrer")
									pre#rm-email-text-content.mb-0.p-3(style="white-space:pre-wrap")

						//- Loading placeholder
						#result-modal-loading.text-center.py-4.d-none
							.spinner-border.spinner-border-sm
							|  Loading...

					.modal-footer
						button.btn.btn-outline-danger.btn-sm.me-auto.d-none#rm-delete-btn
							!= icon('delete', 'me-1')
							| Delete
						button.btn.btn-secondary.btn-sm(type="button" data-bs-dismiss="modal") Close
						button.btn.btn-primary.btn-sm#rm-save-btn
							!= icon('check', 'me-1')
							| Save

		//- Settings modal keeps users anchored in the current app context
		.modal.fade#settingsModal(tabindex="-1" aria-labelledby="settingsModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false")
			.modal-dialog.modal-xl.modal-dialog-scrollable.kk-settings-modal-dialog
				.modal-content
					.modal-header
						h5.modal-title#settingsModalLabel Settings
						button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
					.modal-body#settings-modal-body
						.text-center.py-5.text-muted
							.spinner-border.spinner-border-sm.me-2
							span Loading settings...

		//- Project settings modal keeps project configuration anchored in dashboard context
		.modal.fade#projectSettingsModal(tabindex="-1" aria-labelledby="projectSettingsModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false")
			.modal-dialog.modal-xl.modal-dialog-scrollable.kk-settings-modal-dialog
				.modal-content
					.modal-header
						h5.modal-title#projectSettingsModalLabel Project settings
						button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
					.modal-body#project-settings-modal-body
						.text-center.py-5.text-muted
							.spinner-border.spinner-border-sm.me-2
							span Loading project settings...

		script(src="/socket.io/socket.io.js")
		script(src=`/static/v-${v}/js/icons.js`)
		script(src=`/static/v-${v}/js/autofill_guard.js`)
		script.
			var __ws_url = "#{ws_url}";
			var __host_id = "#{host_id}";
			var __user_name = "#{user ? user.name : ''}";
			var __static_base = "/static/v-#{v}";
			var __avatar_colors = ['#6366f1','#8b5cf6','#ec4899','#f43f5e','#f97316','#eab308','#22c55e','#14b8a6','#06b6d4','#3b82f6'];
			function makeAvatar(name, size) {
				size = size || 'xs';
				var parts = (name || '?').trim().split(' ');
				var initials = parts.length > 1 ? (parts[0][0] + parts[parts.length - 1][0]) : parts[0].substring(0, 2);
				var hash = 0;
				for (var i = 0; i < (name || '').length; i++) hash = (name || '').charCodeAt(i) + ((hash << 5) - hash);
				var bg = __avatar_colors[Math.abs(hash) % __avatar_colors.length];
				return '<span class="avatar avatar-' + size + '" style="background:' + bg + '" title="' + (name || '') + '">' + initials.toUpperCase() + '</span>';
			}
		script(src=`/static/v-${v}/js/vendor.js` type="module")
		script(src=`/static/v-${v}/js/editor.js` type="module")
		script(src=`/static/v-${v}/js/iframe_resizer_parent.js`)
		script(src=`/static/v-${v}/js/email_iframe_renderer.js`)
		script(src=`/static/v-${v}/js/chat.js`)
		script(src=`/static/v-${v}/js/app.js`)
		script(src=`/static/v-${v}/js/search_palette.js`)
		script(src=`/static/v-${v}/js/infinite_scroll.js`)
		script(src=`/static/v-${v}/js/notes.js`)
		script(src=`/static/v-${v}/js/memories.js`)
		script(src=`/static/v-${v}/js/urls.js`)
		script(src=`/static/v-${v}/js/emails.js`)
		script(src=`/static/v-${v}/js/trash.js`)
		script(src=`/static/v-${v}/js/batch.js`)
		include includes/openpanel
		include includes/hyperdx
		if impersonating
			script.
				document.getElementById('exit-impersonation')?.addEventListener('click', async () => {
					const res = await fetch('/api/v1/admin/exit-impersonation', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
					const data = await res.json();
					if (data.ok) window.location.href = data.redirect;
				});
		block scripts
