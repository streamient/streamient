doctype html
html(lang="en")
	head
		meta(charset="UTF-8")
		meta(name="viewport" content="width=device-width, initial-scale=1")
		title #{title || 'Kumbukum'}
		link(href='/static/images/favicon.ico' rel="shortcut icon")
		script(type="importmap").
			{ "imports": { "/static/js/vendor.js": "/static/v-#{v}/js/vendor.js" } }
		link(href=`/static/v-${v}/css/vendor.css` rel="stylesheet")
		link(href=`/static/v-${v}/css/app.css` rel="stylesheet")
		link(href=`/static/v-${v}/css/kumbukum-template1-strict.css` rel="stylesheet")
		include includes/sentry
		block head
	body.kk-template1(class=(hide_chat_sidebar ? 'kk-no-chat-sidebar' : ''))
		block body
			include includes/avatar
			if impersonating
				.alert.alert-warning.text-center.mb-0.rounded-0.py-1(style="position:sticky;top:0;z-index:1060")
					!= icon('shieldWarning', 'me-2')
					strong Sysadmin
					|  — viewing as #{impersonatingName}
					button.btn.btn-sm.btn-outline-dark.ms-3#exit-impersonation Exit

			nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.sticky-top
				.container-fluid
					a.navbar-brand(href="/dashboard")
						include includes/logo_white
					nav.kk-topnav
						a.kk-navbtn(href="/dashboard" class={active: page !== 'graph'}) Projects
						a.kk-navbtn(href="/graph" class={active: page === 'graph'}) Graph
					.ms-auto.d-flex.align-items-center
						if user
							if is_trialing
								a.btn.btn-warning.btn-sm.me-3(href="/settings/subscription" style="padding-top:0.45rem;padding-bottom:0.45rem;")
									!= icon('creditCard', 'me-1')
									span= trial_ends_text || 'Trial'
							if accessible_tenants && accessible_tenants.length > 1
								.dropdown.me-2
									button.btn.btn-outline-light.btn-sm.dropdown-toggle.d-flex.align-items-center.gap-1(type="button" data-bs-toggle="dropdown")
										!= icon('apartment')
										span= active_tenant ? active_tenant.name : 'Select account'
									ul.dropdown-menu.dropdown-menu-end
										each tenant in accessible_tenants
											li
												- var isCurrentTenant = active_tenant && tenant.tenantId === active_tenant.tenantId
												a.dropdown-item.account-switch-link(href="#" data-tenant-id=tenant.tenantId class=(isCurrentTenant ? 'is-current' : '') aria-current=(isCurrentTenant ? 'true' : undefined) tabindex=(isCurrentTenant ? '-1' : undefined))
													.d-flex.justify-content-between.align-items-center.gap-3
														span= tenant.name
														span.kk-account-role-badge= tenant.role
							.dropdown
								button.btn.btn-outline-light.btn-sm.dropdown-toggle.d-flex.align-items-center.gap-1(type="button" data-bs-toggle="dropdown")
									+avatar(user.name, 'xs')
									= user.name
								ul.dropdown-menu.dropdown-menu-end
									li: a.dropdown-item(href="/settings/profile") Profile & Settings
									li: hr.dropdown-divider
									li: a.dropdown-item(href="/docs" target="_blank") Guides & Help
									li: a.dropdown-item(href="/api/doc" target="_blank") API Docs
									li: hr.dropdown-divider
									li: a.dropdown-item(href="/docs/guide/browser-extension" target="_blank") Browser Extension
									if is_hosted
										li: hr.dropdown-divider
										li: a.dropdown-item(href="/settings/subscription") My Subscription
									li: hr.dropdown-divider
									li: a.dropdown-item(href="#" onclick="logout()") Logout

			.container-fluid.flex-grow-1
				.row.h-100
					aside.col-md-2.bg-light.p-3.sidebar#sidebar
						block sidebar
							.d-flex.justify-content-between.align-items-center.mb-3
								h6.mb-0 My Projects
								button.btn.btn-sm.btn-outline-primary#new-project-btn(title="New project")
									!= icon('add')
							#project-list
							
							a.d-flex.align-items-center.text-decoration-none.text-muted.small(href="/trash")
								!= icon('delete', 'ms-2')
								span.ms-2 Global Trash
								span.ms-auto.d-none#trash-count-badge

					main.col-md-7.p-4#main-content
						#chat-results-panel.d-none.mb-4
							.d-flex.justify-content-between.align-items-center.mb-3
								h6.mb-0
									!= icon('search', 'me-1')
									| Chat Results
								button.btn.btn-sm.btn-outline-secondary#close-chat-results(title="Close results")
									!= icon('close')
							#chat-results-list
						#page-content
							block content

					aside.col-md-3.p-3.border-start#chat-sidebar
						block chat
							include includes/chat_sidebar

		//- Universal modal for viewing/editing/creating items
		.modal.fade#chat-result-modal(tabindex="-1" aria-hidden="true")
			.modal-dialog.modal-xl
				.modal-content
					.modal-header
						span.badge.me-2#result-modal-badge
						h5.modal-title#result-modal-title
						button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
					.modal-body#result-modal-body
						//- Note form
						#result-modal-note.d-none
							.mb-3
								.form-text Title
								input.form-control#rm-note-title(type="text")
							.mb-3
								.form-text Tags
								input.form-control#rm-note-tags(type="text")
							ul.nav.nav-tabs.mb-3
								li.nav-item
									button.nav-link.active#rm-note-tab-preview(type="button") Preview
								li.nav-item
									button.nav-link#rm-note-tab-edit(type="button") Edit
							#rm-note-preview.preview-container.border.border-top-0.rounded-bottom.p-3.mb-3(style="min-height:300px")
							#rm-note-editor.border-0.rounded.p-0.d-none.mb-3(style="min-height:300px")
							.mb-3.position-relative
								.form-text Links
								.source-search-wrap
									!= icon('search', 'source-search-icon')
									input.form-control.rm-link-search(type="text" placeholder="Type to search..." autocomplete="off")
								.rm-link-tags.d-flex.flex-wrap.gap-1.mt-2

						//- Memory form
						#result-modal-memory.d-none
							.mb-3
								.form-text Title
								input.form-control#rm-memory-title(type="text")
							.mb-3
								.form-text Tags
								input.form-control#rm-memory-tags(type="text")
							.mb-3
								.form-text Source
								input.form-control#rm-memory-source(type="text")
							ul.nav.nav-tabs.mb-3
								li.nav-item
									button.nav-link.active#rm-memory-tab-preview(type="button") Preview
								li.nav-item
									button.nav-link#rm-memory-tab-edit(type="button") Edit
							#rm-memory-preview.preview-container.border.border-top-0.rounded-bottom.p-3.mb-3(style="min-height:300px")
							#rm-memory-editor.border-0.rounded.p-0.d-none.mb-3(style="min-height:300px")
							.mb-3.position-relative
								.form-text Links
								.source-search-wrap
									!= icon('search', 'source-search-icon')
									input.form-control.rm-link-search(type="text" placeholder="Type to search..." autocomplete="off")
								.rm-link-tags.d-flex.flex-wrap.gap-1.mt-2

						//- URL form
						#result-modal-url.d-none
							ul.nav.nav-tabs.mb-3.px-3
								li.nav-item
									button.nav-link.active#rm-url-tab-details(type="button") Details
								li.nav-item
									button.nav-link.d-none#rm-url-tab-pages(type="button")
										| Crawled pages
										span.badge.rounded-pill.ms-2#rm-url-tab-pages-count 0
							#rm-url-pane-details
								.d-flex.mb-3.w-100.px-3
									.d-none.pe-5.pt-4#rm-url-og-wrap
										img.rounded#rm-url-og-image(alt="" style="object-fit:cover")
									.flex-grow-1
										.mb-3
											.d-flex.justify-content-between.align-items-center
												.form-text URL
												a.form-text.text-decoration-none.d-none#rm-url-visit-link(href="#" target="_blank" rel="noopener")
													span Visit
											input.form-control#rm-url-input(type="url" autofocus)
										.mb-3
											.form-text Title (optional)
											input.form-control#rm-url-title(type="text")
										.mb-4
											.form-text Description (optional)
											textarea.form-control#rm-url-description(type="text" rows="3")
										.mb-3.form-check
											input.form-check-input#rm-url-crawl(type="checkbox")
											label.form-check-label(for="rm-url-crawl") Enable full-site crawling
											.text-muted.fs-9 If checked will index all pages of URL 
										//- .mb-3.d-none#rm-url-crawl-wrap
										//- 	.form-text Crawled pages
										//- 	.small.text-muted.mb-2#rm-url-crawl-meta
								.mb-3.px-3.position-relative
									.form-text Links (optional)
									.source-search-wrap
										!= icon('search', 'source-search-icon')
										input.form-control.rm-link-search(type="text" placeholder="Type to search..." autocomplete="off")
									.rm-link-tags.d-flex.flex-wrap.gap-1.mt-2
							#rm-url-pane-pages.d-none.px-3.pb-2
								.d-flex.justify-content-between.align-items-center.mb-2
									.small.text-muted Crawled page URLs (opens in new tab)
									.d-flex.gap-2
										button.btn.btn-sm.btn-outline-secondary(type="button")#rm-url-resync-btn
											!= icon('sync', 'me-1')
											| Resync now
										button.btn.btn-sm.btn-outline-danger(type="button")#rm-url-delete-pages-btn
											!= icon('delete', 'me-1')
											| Delete pages
								.list-group#rm-url-crawl-list
								button.btn.btn-sm.btn-outline-secondary.mt-2.d-none(type="button")#rm-url-crawl-load-more-btn Load more

						//- Email details (read-only)
						#result-modal-email.d-none
							ul.nav.nav-tabs.mb-3.px-3
								li.nav-item
									button.nav-link.active#rm-email-tab-details(type="button") Details
								li.nav-item
									button.nav-link#rm-email-tab-body(type="button") Body
							#rm-email-pane-details.px-3
								.row.g-3
										.col-md-8#rm-email-main-col
										.mb-2
											.form-text Subject
											input.form-control#rm-email-subject(type="text" readonly)
										.mb-2
											.form-text From
											input.form-control#rm-email-from(type="text" readonly)
										.mb-2
											.form-text To
											input.form-control#rm-email-to(type="text" readonly)
										.mb-2
											.form-text Cc
											input.form-control#rm-email-cc(type="text" readonly)
										.mb-2
											.form-text Bcc
											input.form-control#rm-email-bcc(type="text" readonly)
										.mb-2
											.form-text Message ID
											textarea.form-control#rm-email-message-id(rows="2" readonly)
										.mb-2
											.form-text References
											textarea.form-control#rm-email-references(rows="3" readonly)
										.col-md-4.d-none#rm-email-thread-col
										.form-text Thread
											#rm-email-thread.small
							#rm-email-pane-body.d-none.px-3.pb-2
								.form-text Body / Attachment Text
								#rm-email-content.preview-container.border.rounded.p-3(style="min-height:220px; white-space:pre-wrap")

						//- Loading placeholder
						#result-modal-loading.text-center.py-4.d-none
							.spinner-border.spinner-border-sm
							|  Loading...

					.modal-footer
						button.btn.btn-outline-danger.btn-sm.me-auto.d-none#rm-delete-btn
							!= icon('delete', 'me-1')
							| Delete
						button.btn.btn-secondary.btn-sm(type="button" data-bs-dismiss="modal") Close
						button.btn.btn-primary.btn-sm#rm-save-btn
							!= icon('check', 'me-1')
							| Save

		script(src="/socket.io/socket.io.js")
		script(src=`/static/v-${v}/js/icons.js`)
		script.
			var __ws_url = "#{ws_url}";
			var __host_id = "#{host_id}";
			var __user_name = "#{user ? user.name : ''}";
			var __avatar_colors = ['#6366f1','#8b5cf6','#ec4899','#f43f5e','#f97316','#eab308','#22c55e','#14b8a6','#06b6d4','#3b82f6'];
			function makeAvatar(name, size) {
				size = size || 'xs';
				var parts = (name || '?').trim().split(' ');
				var initials = parts.length > 1 ? (parts[0][0] + parts[parts.length - 1][0]) : parts[0].substring(0, 2);
				var hash = 0;
				for (var i = 0; i < (name || '').length; i++) hash = (name || '').charCodeAt(i) + ((hash << 5) - hash);
				var bg = __avatar_colors[Math.abs(hash) % __avatar_colors.length];
				return '<span class="avatar avatar-' + size + '" style="background:' + bg + '" title="' + (name || '') + '">' + initials.toUpperCase() + '</span>';
			}
		script(src=`/static/v-${v}/js/vendor.js` type="module")
		script(src=`/static/v-${v}/js/editor.js` type="module")
		script(src=`/static/v-${v}/js/chat.js`)
		script(src=`/static/v-${v}/js/app.js`)
		script(src=`/static/v-${v}/js/notes.js`)
		script(src=`/static/v-${v}/js/memories.js`)
		script(src=`/static/v-${v}/js/urls.js`)
		script(src=`/static/v-${v}/js/emails.js`)
		script(src=`/static/v-${v}/js/trash.js`)
		script(src=`/static/v-${v}/js/batch.js`)
		include includes/openpanel
		if impersonating
			script.
				document.getElementById('exit-impersonation')?.addEventListener('click', async () => {
					const res = await fetch('/api/v1/admin/exit-impersonation', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
					const data = await res.json();
					if (data.ok) window.location.href = data.redirect;
				});
		block scripts
