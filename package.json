  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scarf/scarf": "^1.4.0",
    "esbuild": "^0.28.1",
    "nodemon": "^3.1.14",
    "vue-demi": "^0.14.10"
  },
  "packageManager": "pnpm@11.8.0"
}
