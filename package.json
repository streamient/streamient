{
  "name": "kumbukum",
  "version": "0.1.0",
  "private": true,
  "description": "Everything your AI needs to remember — Notes, Memory, URLs, AI Chat",
  "license": "AGPL-3.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node --optimize_for_size --max-old-space-size=4096 --import ./tracing.js app.js",
    "build": "node build.js",
    "dev": "nodemon --max-old-space-size=4096 --trace-warnings --import ./tracing.js app.js",
    "test": "node --test --test-force-exit test/*.test.js test/**/*.test.js",
    "test:mcp": "node --test --test-force-exit test/mcp/**/*.test.js",
    "docs:dev": "pnpm --filter @kumbukum/docs dev",
    "docs:build": "pnpm --filter @kumbukum/docs build",
    "docs:preview": "pnpm --filter @kumbukum/docs preview"
  },
  "nodemonConfig": {
    "watch": [
      "app.js",
      "config.js",
      "db.js",
      "routes/",
      "middleware/",
      "model/",
      "modules/",
      "services/",
      "views/",
      "src/",
      "public/css/app.css",
      "public/js/autofill_guard.js",
      "public/js/auth.js"
    ],
    "ext": "js,pug,css",
    "ignore": [
      "public/js/vendor.js",
      "public/js/editor.js",
      "public/css/vendor.css"
    ],
    "exec": "node build.js && node --import ./tracing.js app.js"
  },
  "dependencies": {
    "@fontsource-variable/material-symbols-outlined": "^5.2.45",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@fontsource-variable/noto-sans-mono": "^5.2.10",
    "@hyperdx/node-opentelemetry": "^0.11.0",
    "@iframe-resizer/child": "^5.5.9",
    "@iframe-resizer/parent": "^5.5.9",
    "@keyv/valkey": "^1.0.11",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/api-logs": "0.219.0",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-logs-otlp-http": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-logs": "0.219.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "@simplewebauthn/server": "^13.3.1",
    "@socket.io/redis-streams-adapter": "^0.3.1",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-blockquote": "^3.27.1",
    "@tiptap/extension-bullet-list": "^3.27.1",
    "@tiptap/extension-code-block": "^3.27.1",
    "@tiptap/extension-heading": "^3.27.1",
    "@tiptap/extension-horizontal-rule": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-ordered-list": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@yaireo/tagify": "^4.37.1",
    "archiver": "^8.0.0",
    "axios": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
